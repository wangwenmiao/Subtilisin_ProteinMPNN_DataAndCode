# NPT Equilibration with Berendsen Barostat and Strong Backbone Restraints
&cntrl
  imin=0,                ! Perform MD
  irest=1,               ! Restart from previous run (read coordinates and velocities)
  ntx=5,                 ! Read coordinates, velocities, and box from binary restart file (.ncrst)

  nstlim=250000,         ! Number of MD steps: 250000 steps * 0.002 ps/step = 500 ps
  dt=0.002,              ! Time step in ps (1 fs)

  ! SHAKE for bonds involving hydrogen
  ntc=2,                 ! Constrain bonds involving hydrogen
  ntf=2,                 ! Do not calculate forces for constrained H-bonds

  ! Cutoff for non-bonded interactions
  cut=10.0,              ! Cutoff in Angstroms

  ! Periodic boundary conditions and pressure control
  ntb=2,                 ! Constant pressure periodic boundary conditions
  ntp=1,
  barostat=1,
  pres0=1.01325,         ! Target pressure in bar (standard atmosphere)
  taup=2.0,              ! Pressure relaxation time in ps (common value: 1.0-5.0 ps)
  
  ! Temperature control
  ntt=3,                 ! Langevin thermostat
  gamma_ln=2.0,          ! Collision frequency for Langevin thermostat (ps^-1)
  temp0=300.0,           ! Target temperature in Kelvin

  ! Output control
  ntpr=5000,             ! Print energy information to mdout every 1000 steps (1 ps)
  ntwx=5000,             ! Write coordinates to trajectory file every 1000 steps (1 ps)
  ntwr=10000,            ! Write restart file every 10000 steps (10 ps)
  ioutfm=1,              ! Write trajectory in NetCDF format (recommended)
  ntxo=2,                ! Write restart file in NetCDF format (binary, recommended)

  ! Positional restraints
  ntr=1,                 ! Use positional restraints
  restraintmask=':1-1000 & @C,CA,N', ! Restrain backbone C, CA, N atoms of residues 1-1000
  restraint_wt=5.0,     ! Restraint force constant in kcal/mol/Angstrom^2 (strong restraint)
/
